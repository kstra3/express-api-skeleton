{
  "name": "express-api-skeleton",
  "version": "1.0.0",
  "description": "Production-ready Express REST API skeleton",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "jest --coverage --detectOpenHandles --runInBand",
    "test:watch": "jest --watch",
    "prepare": "husky install .husky"
  },
  "dependencies": {
    "express": "^4.21.0",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "joi": "^17.11.0",
    "http-status": "^1.7.4",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.3",
    "redis": "^4.7.0",
    "multer": "^1.4.5-lts.1",
    "swagger-ui-express": "^5.0.1",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "husky": "^9.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
